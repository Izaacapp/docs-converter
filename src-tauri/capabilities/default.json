{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Pick a PDF, POST it to the converter API, and save the result.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*/*" },
        { "url": "http://*/*" },
        { "url": "https://*:*/*" },
        { "url": "https://*/*" }
      ]
    }
  ]
}
