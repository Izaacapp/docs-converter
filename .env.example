# Copy to .env (gitignored). With direnv, `.envrc` auto-loads it.

# context7 — read by scripts/ctx7.sh and the project MCP server (.mcp.json).
CONTEXT7_API_KEY=

# Converter server — runs the doc-convert HTTP service (built by deploy/serve.sh).
CONVERTER_SERVER_HOST=192.168.1.x
CONVERTER_SERVER_USER=
CONVERTER_SERVER_PASSWORD=
CONVERTER_API_PORT=8088

# The app + tests convert off this API.
CONVERTER_API_URL=http://192.168.1.x:8088
VITE_CONVERTER_API_URL=http://192.168.1.x:8088
