# Copy to .env and fill in. .env is gitignored.

# context7 — used by scripts/ctx7.sh to fetch current library docs.
# Get a key at https://context7.com (or run: scripts/ctx7.sh login).
CONTEXT7_API_KEY=

# ── Docling engine ──────────────────────────────────────────────────────────
# Homelab conversion service. Run `docling-serve` on the homelab (which already
# has LaTeX + GPU); when set, the sidecar POSTs PDFs here instead of running
# docling locally. Leave blank to use the local `docling` CLI.
#   homelab setup:  pip install "docling-serve[ui]" && docling-serve run --port 5001
DOCLING_SERVE_URL=http://homelab.local:5001

# Homelab host (informational — where docling-serve + LaTeX live).
HOMELAB_HOST=homelab.local

# Local docling binary, used when DOCLING_SERVE_URL is blank. Point at a venv
# so the Tauri sidecar finds it without a global install.
#   local setup:  python3 -m venv .venv && .venv/bin/pip install docling
DOCLING_BIN=./.venv/bin/docling
