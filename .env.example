# Copy to .env (gitignored) and fill in. With direnv, `.envrc` auto-loads this.

# context7 — read by scripts/ctx7.sh and the project MCP server (.mcp.json).
# Get a key at https://context7.com (or: scripts/ctx7.sh login).
CONTEXT7_API_KEY=

# Docling engine. Set a docling-serve URL (homelab GPU + LaTeX) to convert
# remotely, or leave blank to use the local docling CLI at DOCLING_BIN.
#   homelab:  pip install "docling-serve[ui]" && docling-serve run --port 5001
#   local:    python3 -m venv .venv && .venv/bin/pip install docling
DOCLING_SERVE_URL=http://homelab.local:5001
DOCLING_BIN=./.venv/bin/docling
