# build output — centralized in .artifacts/ (see .cargo/config.toml, vite.config.ts)
.artifacts/
node_modules/
**/target/
.svelte-kit/
src-tauri/gen/

# bundled sidecars (platform-specific; produced by scripts/build-sidecar.sh)
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep

# python venv + direnv cache
.venv/
.direnv/

# secrets & local
.env
*.log

# os
.DS_Store
